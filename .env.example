# ══════════════════════════════════════════════════════════════════════════════
# ViroScan — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs.
# NE JAMAIS committer .env.local dans git.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Clerk Auth (OBLIGATOIRE) ──────────────────────────────────────────────────
# Obtenir sur : https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URLs de redirection Clerk (laisser telles quelles)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ══════════════════════════════════════════════════════════════════════════════
# BASE DE DONNÉES — choisir UN seul bloc selon la plateforme
# ══════════════════════════════════════════════════════════════════════════════

# ── Option A : Railway (recommandé) ───────────────────────────────────────────
# Railway génère DATABASE_URL automatiquement lors de l'ajout du plugin Postgres
# Format : postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@containers-us-west-XX.railway.app:XXXX/railway

# ── Option B : Vercel Postgres ────────────────────────────────────────────────
# Obtenir sur : https://vercel.com/storage/postgres
# POSTGRES_URL=postgres://user:password@host:5432/dbname

# ══════════════════════════════════════════════════════════════════════════════
# STOCKAGE DES FICHIERS — choisir UN seul bloc selon la plateforme
# ══════════════════════════════════════════════════════════════════════════════

# ── Option A : S3-compatible pour Railway (Cloudflare R2 recommandé) ──────────
# Cloudflare R2 : https://dash.cloudflare.com → R2 → Create bucket
S3_BUCKET_NAME=viroscan-archives
S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
S3_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
S3_REGION=auto
# S3_FORCE_PATH_STYLE=true   ← décommenter pour MinIO / certains providers

# ── Option B : AWS S3 standard ────────────────────────────────────────────────
# S3_BUCKET_NAME=viroscan-archives
# S3_REGION=eu-west-3
# S3_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# S3_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# (pas de S3_ENDPOINT_URL pour AWS S3 natif)

# ── Option C : Vercel Blob ────────────────────────────────────────────────────
# Obtenir sur : https://vercel.com/storage/blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Stripe (OBLIGATOIRE pour les paiements) ───────────────────────────────────
# Obtenir sur : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ID_PREMIUM=price_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── URL de l'application (OBLIGATOIRE en production) ─────────────────────────
# Railway génère une URL : https://votre-app.up.railway.app
NEXT_PUBLIC_APP_URL=https://votre-app.up.railway.app
NEXT_PUBLIC_SITE_URL=https://votre-app.up.railway.app

# ─── Resend (feedback email) ──────────────────────────────────────────────────
# Obtenir la clé sur : https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FEEDBACK_EMAIL=vous@votredomaine.com
# onboarding@resend.dev = sandbox (envoi limité à l'email du compte Resend)
# Après vérification de domaine sur resend.com/domains :
# RESEND_FROM_EMAIL=ViroScan Feedback <feedback@votredomaine.com>
RESEND_FROM_EMAIL=ViroScan Feedback <onboarding@resend.dev>

# ─── VirusTotal (OPTIONNEL) ────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=

# ─── Limites d'upload (OPTIONNEL — valeurs par défaut indiquées) ───────────────
NEXT_PUBLIC_MAX_FREE_SIZE_MB=50
NEXT_PUBLIC_MAX_PREMIUM_SIZE_MB=500

# ─── TTL des fichiers (OPTIONNEL — valeurs par défaut indiquées) ───────────────
FILE_TTL_FREE_HOURS=2
FILE_TTL_PREMIUM_HOURS=48
