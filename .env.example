# ══════════════════════════════════════════════════════════════════════════════
# ViroScan — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs.
# NE JAMAIS committer .env.local dans git.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Clerk Auth (OBLIGATOIRE) ──────────────────────────────────────────────────
# Obtenir sur : https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URLs de redirection Clerk (laisser telles quelles)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Base de données (OBLIGATOIRE en production) ───────────────────────────────
# Obtenir sur : https://vercel.com/storage/postgres
# Si absent → SQLite local (dev uniquement, non supporté sur Vercel)
POSTGRES_URL=postgres://user:password@host:5432/dbname

# ─── Stockage des fichiers (OBLIGATOIRE en production) ─────────────────────────
# Obtenir sur : https://vercel.com/storage/blob
# Si absent → stockage local sur disque (dev uniquement)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Stripe (OBLIGATOIRE pour les paiements) ───────────────────────────────────
# Obtenir sur : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Price ID de l'abonnement Premium mensuel
STRIPE_PRICE_ID_PREMIUM=price_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Secret du webhook Stripe (pour valider les événements entrants)
# Obtenir sur : https://dashboard.stripe.com/webhooks → endpoint /api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── URL de l'application (OBLIGATOIRE en production) ─────────────────────────
# Remplacer par ton domaine Vercel ou custom
NEXT_PUBLIC_APP_URL=https://ton-site.vercel.app
NEXT_PUBLIC_SITE_URL=https://ton-site.vercel.app

# ─── Initialisation de la base (OBLIGATOIRE au 1er déploiement) ────────────────
# Utilisé pour protéger GET /api/setup en production
# Génère une valeur aléatoire : openssl rand -hex 32
SETUP_SECRET=une_valeur_secrete_aleatoire_longue

# ─── VirusTotal (OPTIONNEL) ────────────────────────────────────────────────────
# Active la vérification des hash via l'API VirusTotal
# Obtenir sur : https://www.virustotal.com/gui/my-apikey
# Si absent → scan heuristique local uniquement
VIRUSTOTAL_API_KEY=

# ─── Limites d'upload (OPTIONNEL — valeurs par défaut indiquées) ───────────────
NEXT_PUBLIC_MAX_FREE_SIZE_MB=50
NEXT_PUBLIC_MAX_PREMIUM_SIZE_MB=500

# ─── TTL des fichiers (OPTIONNEL — valeurs par défaut indiquées) ───────────────
FILE_TTL_FREE_HOURS=2
FILE_TTL_PREMIUM_HOURS=48
